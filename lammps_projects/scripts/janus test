#janus particle
"""Generates evenly distributed points on a sphere."""
# Atoms: ID, molecule-ID, type, x, y, z
import numpy as np
def calculate_n_for_radius(radius, density_factor=4):
        """
        radius: The radius of your sphere
        density_factor: Points per unit of surface area
        """
        surface_area = 4 * np.pi * (radius**2)
        return int(surface_area * density_factor)
if __name__ == "__main__":
    n_points=calculate_n_for_radius(1.5)
    b=1
    jr=3
    phi = np.pi * (3. - np.sqrt(5.))  # Golden angle in radians
    filename="janus.data"
    with open(filename, 'w') as f:
        # Header
        f.write("LAMMPS Polymer Data File\n\n")
        f.write(f"{n_points} atoms\n\n")
        
        
        f.write("2 atom types\n\n")
        f.write("0.0 12.0 xlo xhi\n")
        f.write("0.0 12.0 ylo yhi\n")
        f.write("0.0 12.0 zlo zhi\n\n")
        f.write("Atoms\n\n")
    
        
        for i in range(n_points):
            y =1 - (i / float(n_points - 1)) * 2  # y goes from -1 to 1
            radius = np.sqrt(1 - y * y)  # radius at y

            theta = phi * i  # golden angle increment

            x = np.cos(theta) * radius
            z = np.sin(theta) * radius
            f.write(f"{b} 1 {3 if theta%(2*np.pi)<np.pi else 4} {jr*(x+2):.4f} {jr*(y+2):4f} {jr*(z+2):4f}\n")
            b+=1        



    
    print("File 'polymer_chain_multiple_3_jr3.data' has been created.")